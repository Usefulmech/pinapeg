# Pinapeg frontend environment.
# Copy this file to frontend/.env.
# Only public browser-safe values go here.

VITE_API_URL=http://localhost:8000/v1

# Local fallback identity while Neon Auth / Google sign-in is being wired.
VITE_DEMO_USER_ID=local-demo-user

# Neon Auth public URL for production-style Google sign-in/sign-up.
VITE_NEON_AUTH_URL=

# Optional later: browser push subscription uses the public VAPID key.
VITE_VAPID_PUBLIC_KEY=
