# Pinapeg backend environment.
# Copy this file to backend/.env and fill only the values you are ready to use.
# Secrets belong here, never in frontend/.env.

APP_ENV=development
ALLOW_DEV_IDENTITY=true

# Storage
# Use memory while setting up. Switch to postgres after Neon DATABASE_URL is ready and migrations have run.
STORAGE_MODE=memory
DATABASE_URL=



# Local frontend origins allowed to call FastAPI.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
FRONTEND_APP_URL=http://localhost:5173

# OpenAI powers semantic memory, richer review/essence, and voice transcription.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
TRANSCRIPTION_MODEL=whisper-1
SUMMARY_MODEL=gpt-4o-mini

# Google OAuth for Calendar and Gmail integrations.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/integrations/google/callback
GOOGLE_OAUTH_STATE_SECRET=replace-with-a-long-random-string
TOKEN_ENCRYPTION_KEY=replace-with-a-32-byte-url-safe-key

# Web Push / PWA notifications. Optional until push reminders are enabled.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
