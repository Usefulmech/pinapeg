# Pinapeg environment map.
# The app does not read this root file directly.
# Copy backend/.env.example to backend/.env for secrets.
# Copy frontend/.env.example to frontend/.env for public browser values.

## backend/.env
APP_ENV=development
ALLOW_DEV_IDENTITY=true
STORAGE_MODE=memory
DATABASE_URL=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
FRONTEND_APP_URL=http://localhost:5173
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
TRANSCRIPTION_MODEL=whisper-1
SUMMARY_MODEL=gpt-4o-mini
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/integrations/google/callback
GOOGLE_OAUTH_STATE_SECRET=replace-with-a-long-random-string
TOKEN_ENCRYPTION_KEY=replace-with-a-32-byte-url-safe-key
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

## frontend/.env
VITE_API_URL=http://localhost:8000/v1
VITE_DEMO_USER_ID=local-demo-user
VITE_NEON_AUTH_URL=
VITE_VAPID_PUBLIC_KEY=
